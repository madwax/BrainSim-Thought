<Window x:Class="BrainSimulator.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow"
        Height="600"
        Width="800">
	<DockPanel Margin="0,0,0,0" >
		<Menu DockPanel.Dock="Top" x:Name="MainMenu" Height="26" Margin="0,0" VerticalAlignment="Top" Background="LightGray" >
			<MenuItem Header="_File">
				<MenuItem Header="_New" Click="button_FileNew_Click" HotKey="Ctrl+N">
					<MenuItem.Icon>
						<Image Source="/Resources/Icons/NewFile_16x.png"/>
					</MenuItem.Icon>
				</MenuItem>
				<MenuItem Header="_Open" Click="buttonLoad_Click" HotKey="Ctrl+O">
					<MenuItem.Icon>
						<Image Source="/Resources/Icons/OpenFile_16x.png"/>
					</MenuItem.Icon>
				</MenuItem>
				<MenuItem Header="_Save" Click="buttonSave_Click" HotKey="Ctrl+S">
					<MenuItem.Icon>
						<Image Source="/Resources/Icons/Save_16x.png"/>
					</MenuItem.Icon>
				</MenuItem>
				<MenuItem Header="Save _As" Click="buttonSaveAs_Click">
					<MenuItem.Icon>
						<Image Source="Resources/Icons/SaveAs_16x.png"></Image>
					</MenuItem.Icon>
				</MenuItem>
				<Separator />
				<MenuItem Header="Recent" x:Name="MRUListMenu">
				</MenuItem>
				<Separator />
				<MenuItem Header="_Exit" Click="button_Exit_Click" >
					<MenuItem.Icon>
						<TextBlock FontSize="16" FontFamily="Segoe MDL2 Assets" Foreground="#FF00539C" >&#xE711;</TextBlock>
					</MenuItem.Icon>
				</MenuItem>
			</MenuItem>
		</Menu>
		<Grid>
			<Grid.Background>
				<ImageBrush Source="/Resources/BrainSimBackground.jpg" Stretch="Fill"/>
			</Grid.Background>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>

			<!-- The Toolbar -->
			<DockPanel Grid.Row="0" Grid.Column="0" x:Name="MainToolBar" Grid.ColumnSpan="3" Height="30" Margin="7,5,0,0" VerticalAlignment="Top">
				<Button x:Name="NewButton" Click="button_FileNew_Click" VerticalAlignment="Top" ToolTip.Tip="New File">
					<Image Source="/Resources/Icons/NewFile_16x.png" Height="20"  ></Image>
				</Button>
				<Button x:Name="OpenButton" Click="buttonLoad_Click" VerticalAlignment="Top" ToolTip.Tip="Open File">
					<Image Source="/Resources/Icons/OpenFile_16x.png" Height="20"></Image>
				</Button>
				<Button x:Name="SaveButton" Click="buttonSave_Click" VerticalAlignment="Top" ToolTip.Tip="Save File" >
					<Image Source="/Resources/Icons/Save_16x.png" Height="20"></Image>
				</Button>
				<Button x:Name="SaveAsButton" Click="buttonSaveAs_Click" VerticalAlignment="Top" ToolTip.Tip="Save File As"  >
					<Image Source="/Resources/Icons/SaveAs_16x.png" Height="20"></Image>
				</Button>
				<Label IsVisible="False"  Width="30"></Label>
				<Label IsVisible="False" Width="5"></Label>
				<Label IsVisible="False" Width="30"></Label>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
					<Label Content="Add Module:" Foreground="White"/>
					<ComboBox x:Name="ModuleListComboBox"  VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Width="271" Height="26" IsEditable="True" DropDownClosed="ModuleListComboBox_DropDownClosed" >
					</ComboBox>
				</StackPanel>
			</DockPanel>
			<Border BorderThickness="4" Width="180" Grid.Column="0" Grid.Row="1" BorderBrush="Gray" HorizontalAlignment="Left">
				<StackPanel x:Name="ActiveModuleSP">
				</StackPanel>
			</Border>
		</Grid>
	</DockPanel>
</Window>
