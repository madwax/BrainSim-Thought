<Window x:Class="BrainSimulator.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Brain Simulator Thought"
        Height="600"
        Width="800">
	<Window.Styles>
		<Style Selector="DockPanel.Toolbar">
			<Setter Property="Background" Value="rgba(100,100,100,0.25)" />
			<Setter Property="VerticalAlignment" Value="Top"/>
			<Setter Property="Margin" Value="5,5,5,5"/>
			<Style Selector="^ > Button">
				<Setter Property="Height" Value="25" />
				<Setter Property="Width" Value="25" />
				<Style Selector="^ > Image">
					<Setter Property="Height" Value="20" />
					<Setter Property="Width" Value="20" />

				</Style>
			</Style>
		</Style>
		<Style Selector="StackPanel.AddModules">
			<Style Selector="^ > ComboBox">
				<Setter Property="Background" Value="White"/>
				<Setter Property="VerticalAlignment" Value="Top"/>
			</Style>
		</Style>
	</Window.Styles>
	<DockPanel Margin="0,0,0,0" >
		<Menu DockPanel.Dock="Top" x:Name="MainMenu" Height="26" Margin="0,0" VerticalAlignment="Top" Background="LightGray" >
			<MenuItem Header="_File">
				<MenuItem Header="_New" Click="MainMenu_FileNew" HotKey="Ctrl+N">
					<MenuItem.Icon>
						<Image Source="/Resources/Icons/NewFile_16x.png"/>
					</MenuItem.Icon>
				</MenuItem>
				<MenuItem Header="_Open" Click="MainMenu_FileOpen" HotKey="Ctrl+O">
					<MenuItem.Icon>
						<Image Source="/Resources/Icons/OpenFile_16x.png"/>
					</MenuItem.Icon>
				</MenuItem>
				<MenuItem Header="_Save" Click="MainMenu_FileSave" HotKey="Ctrl+S">
					<MenuItem.Icon>
						<Image Source="/Resources/Icons/Save_16x.png"/>
					</MenuItem.Icon>
				</MenuItem>
				<MenuItem Header="Save _As" Click="MainMenu_FileSaveAs">
					<MenuItem.Icon>
						<Image Source="Resources/Icons/SaveAs_16x.png"></Image>
					</MenuItem.Icon>
				</MenuItem>
				<Separator />
				<MenuItem Header="Recent" x:Name="MRUListMenu">
				</MenuItem>
				<Separator />
				<MenuItem Header="_Exit" Click="MainMenu_FileExit" >
					<MenuItem.Icon>
						<TextBlock FontSize="16" FontFamily="Segoe MDL2 Assets" Foreground="#FF00539C" >&#xE711;</TextBlock>
					</MenuItem.Icon>
				</MenuItem>
			</MenuItem>
		</Menu>
		<Grid>
			<Grid.Background>
				<ImageBrush Source="/Resources/BrainSimBackground.jpg" Stretch="Fill"/>
			</Grid.Background>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>

			<!-- The Toolbar -->
			<DockPanel Classes="Toolbar" Grid.Row="0" Grid.Column="0" x:Name="MainToolBar" Grid.ColumnSpan="3">
				<Button x:Name="NewButton" Click="MainMenu_FileNew" VerticalAlignment="Top" ToolTip.Tip="New UKS File">
					<Image Source="/Resources/Icons/NewFile_16x.png" ></Image>
				</Button>
				<Button x:Name="OpenButton" Click="MainMenu_FileOpen" VerticalAlignment="Top" ToolTip.Tip="Open UKS File">
					<Image Source="/Resources/Icons/OpenFile_16x.png"></Image>
				</Button>
				<Button x:Name="SaveButton" Click="MainMenu_FileSave" VerticalAlignment="Top" ToolTip.Tip="Save UKS File" >
					<Image Source="/Resources/Icons/Save_16x.png"></Image>
				</Button>
				<Button x:Name="SaveAsButton" Click="MainMenu_FileSaveAs" VerticalAlignment="Top" ToolTip.Tip="Save UKS File As"  >
					<Image Source="/Resources/Icons/SaveAs_16x.png"></Image>
				</Button>
				<Label IsVisible="True" Width="65"></Label>
				<StackPanel Classes="AddModules" Orientation="Horizontal" HorizontalAlignment="Left">
					<Label Content="Add Module:" Foreground="White"/>
					<ComboBox x:Name="ModuleListComboBox" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Width="271" Height="26" IsEditable="True" DropDownClosed="ModuleListComboBox_DropDownClosed" >
					</ComboBox>
				</StackPanel>
			</DockPanel>
			<Border BorderThickness="4" Width="180" Grid.Column="0" Grid.Row="1" BorderBrush="Gray" HorizontalAlignment="Left">
				<StackPanel x:Name="ActiveModuleSP">
				</StackPanel>
			</Border>
		</Grid>
	</DockPanel>
</Window>
