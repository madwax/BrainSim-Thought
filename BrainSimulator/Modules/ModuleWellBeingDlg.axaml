<local:ModuleBaseDlg x:Class="BrainSimulator.Modules.ModuleWellBeingDlg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BrainSimulator.Modules"
        mc:Ignorable="d"
        Title="Well-Being" Height="170" Width="360" Background="Gray" ShowInTaskbar="False" FontSize="16" >

    <Grid >
        <Slider x:Name="WellBeingSlider"
                Minimum="-1" Maximum="1"
                LargeChange="0.1" SmallChange="0.05"
                TickFrequency="0.5" IsSnapToTickEnabled="False" TickPlacement="Both"
                Height="40" VerticalAlignment="Top"
                Margin="20,37,20,0"
                ValueChanged="WellBeingSlider_ValueChanged"/>

        <RepeatButton x:Name="DecreaseButton" FontSize="24"
                      Padding="0"
                      Width="40" Height="30"
                      HorizontalAlignment="Left" VerticalAlignment="Bottom"
                      Margin="80,0,0,35"
                      Delay="250" Interval="100"
                      Click="DecreaseButton_Click">
            <TextBlock Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" Height="36"/>
        </RepeatButton>

        <RepeatButton x:Name="IncreaseButton" FontSize="24"
                      Padding="0"
                      Width="40" Height="30"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                      Margin="0,0,86,35"
                      Delay="250" Interval="100"
                      Click="IncreaseButton_Click">
            <TextBlock Text="+" VerticalAlignment="Center" Height="36"/>
        </RepeatButton>
    </Grid>
</local:ModuleBaseDlg>