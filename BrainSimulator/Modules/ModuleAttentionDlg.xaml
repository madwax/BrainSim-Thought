<local:ModuleBaseDlg x:Class="BrainSimulator.Modules.ModuleAttentionDlg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BrainSimulator.Modules"
        mc:Ignorable="d"
        Title="Attention" Height="220" Width="520" Background="Gray" ShowInTaskbar="False">
    <Grid x:Name="TheGrid" Margin="10,10,10,40" SizeChanged="TheGrid_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>  
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="40"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                   Text="Center of Attention" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Horizontal (90&#176;)" />
        <Slider x:Name="HorizontalSlider" Grid.Row="1" Grid.Column="1"
                Minimum="-180" Maximum="180" TickFrequency="10" IsSnapToTickEnabled="False"
                ValueChanged="Slider_ValueChanged" />
        <TextBlock x:Name="HorizontalValue" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right"
                   VerticalAlignment="Center" Width="60" TextAlignment="Right"/>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Vertical (90&#176;)" />
        <Slider x:Name="VerticalSlider" Grid.Row="2" Grid.Column="1"
                Minimum="-90" Maximum="90" TickFrequency="5" IsSnapToTickEnabled="False"
                ValueChanged="Slider_ValueChanged" />
        <TextBlock x:Name="VerticalValue" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right"
                   VerticalAlignment="Center" Width="60" TextAlignment="Right"/>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Current Focus:" />
        <TextBlock x:Name="FocusValue" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                   Margin="4,4,0,0" TextTrimming="CharacterEllipsis"/>
    </Grid>
</local:ModuleBaseDlg>