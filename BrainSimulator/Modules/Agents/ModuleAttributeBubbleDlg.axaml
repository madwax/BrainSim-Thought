<Window x:Class="BrainSimulator.Modules.ModuleAttributeBubbleDlg"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attribute Bubble Agent" 
        ShowInTaskbar="False"
    >
    <Grid Name="theGrid" SizeChanged="TheGrid_SizeChanged" >
        <Button Content="Run Once" HorizontalAlignment="Left" Margin="100,0,0,29" Width="105" Click="Button_Click" Height="30" VerticalAlignment="Bottom"/>
        <ScrollViewer Name="DebugMessageView" Margin="25,24,20,86" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
    	    <ListBox Name="DebugMessages" ></ListBox>	
        </ScrollViewer>
        <!--<TextBox Name="tbMessages" Margin="25,24,20,86" TextWrapping="Wrap" Text="" VerticalScrollBarVisibility="Auto"/>-->
        <CheckBox Name="Enable" HorizontalAlignment="Left" Margin="18,0,0,34" Content="Enabled" IsChecked="False" Checked="Enable_Checked" Unchecked="Enable_Checked" Height="19" VerticalAlignment="Bottom" />
    </Grid>
</Window>
