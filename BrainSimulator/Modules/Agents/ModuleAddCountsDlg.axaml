<Window x:Class="BrainSimulator.Modules.ModuleAddCountsDlg"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Counts Agent" 
        Height="250" 
        Width="300" 
        Background="Gray" 
        ShowInTaskbar="False">
    <Grid Name="theGrid" SizeChanged="TheGrid_SizeChanged" >
        <Button Content="Run Once" HorizontalAlignment="Left" Height="30" Margin="100,0,0,29" VerticalAlignment="Bottom" Width="105" Click="Button_Click"/>
        <TextBox Name="tbMessages" Margin="25,24,20,86" TextWrapping="Wrap" Text=""/>
        <CheckBox Name="Enable" HorizontalAlignment="Left" Margin="18,0,0,34" Content="Enabled" IsChecked="False" VerticalAlignment="Bottom" IsCheckedChanged="Enable_Checked" />
    </Grid>
  </Window>
